<configs>
    <append xpath="/blocks">
        <block name="nesTV">
            <property name="CreativeMode" value="Player"/>
            <property name="Class" value="Powered"/>
            <property name="RequiredPower" value="5"/>
            <property name="CustomIcon" value="tvSmallStand1x1"/>
            <property name="Extends" value="tvSmallStand1x1"/>
            <property name="DisplayInfo" value="Name"/>
            <property name="DescriptionKey" value="nesTV_desc"/>
            <property name="ActivationText" value="nesTV_activate"/>
        </block>
        <block name="nesConsole">
            <property name="CreativeMode" value="Player"/>
            <property name="Class" value="Workstation"/>
            <property class="Workstation">
                <property name="Modules" value="tools,output"/>
                <property name="CraftingAreaRecipes" value="nesConsole"/>
                <property name="ToolNames" value="1"/>
            </property>
            <property name="CustomIcon" value="nesTV"/>
            <property name="WorkstationIcon" value="nesTV"/>
            <property name="Shape" value="New"/>
            <property name="Model" value="@:Shapes/Cube_A.fbx"/>
            <property name="Texture" value="65"/>
            <property name="Material" value="MelectricParts"/>
            <property name="MaxDamage" value="500"/>
            <property name="Place" value="TowardsPlacerInverted"/>
            <property name="Stacknumber" value="1"/>
            <property name="DisplayInfo" value="Name"/>
            <property name="DescriptionKey" value="nesConsole_desc"/>
            <property name="OpenSound" value="UseActions/open_safe"/>
            <property name="CloseSound" value="UseActions/close_safe"/>
        </block>
    </append>
</configs>
